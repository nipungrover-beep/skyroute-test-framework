# Base URL of the application under test.
# Local dev server:
BASE_URL=http://localhost:5173

# Optional: pre-provisioned test account for authenticated flows.
# If not set, login "happy path" tests are skipped (see tests/functional/login.spec.ts).
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# Release tag used to label this test run in reports/ and defects/ (e.g. 2026.07-R1).
# Defaults to "local" if not set.
RELEASE_TAG=

# Jira (Atlassian Cloud) — used by scripts/fetch-jira-issue.js to pull issue
# details for test planning. Generate a token at
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
